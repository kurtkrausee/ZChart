{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Modus für Library-Kompatibilität */
    "moduleResolution": "node",          // Geändert von 'bundler' zu 'node' für bessere Erkennung
    "moduleDetection": "force",
    "esModuleInterop": true,             // Wichtig für den Import in React/Vite
    
    /* FIXES FÜR LIBRARY BUILD */
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",

    /* Typen-Sicherheit */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}